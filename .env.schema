# API base URL for the Power Apps backend
# @required
VITE_API_BASE_URL="http://localhost:3001/api"

# SonarQube token for code quality scans
# @required @sensitive @example="sqp_xxxxxxxxxxxx"
SONAR_TOKEN=

# Database connection string (if using PostgreSQL MCP)
# @optional @sensitive @example="postgresql://user:pass@localhost:5432/dbname"
DATABASE_URL=

VITE_API_BASE_URL=http://localhost:3001/api

# -----------------------------------------------------------------------------
# Sentry — leave unset to keep Sentry disabled in local dev
# -----------------------------------------------------------------------------
# Get a DSN from https://sentry.io after creating a project. The DSN is
# public — designed to be exposed in client bundles. See skills/observability.md
# for the full setup guide.
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=development
# VITE_SENTRY_RELEASE=
